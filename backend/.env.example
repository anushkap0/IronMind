# Copy this file to .env and fill in real values.

APP_NAME=IronMind Fitness API
ENV=development

# Generate a strong random key, e.g. `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Use sqlite for local dev, or a Postgres URL in production, e.g.:
# postgresql://user:password@db:5432/fitness
DATABASE_URL=sqlite:///./fitness.db

FRONTEND_ORIGIN=http://localhost:5173

# Hugging Face Inference API — create a free token at
# https://huggingface.co/settings/tokens (read access is enough).
# Leave HF_API_TOKEN empty to run the chatbot in offline "demo mode".
# Model must be picked from a live, supported provider (see chat notes) —
# check https://huggingface.co/models?pipeline_tag=text-generation for what's
# currently available, and set provider="..." in app/rag/rag_engine.py to match.
HF_API_TOKEN=
HF_MODEL=Qwen/Qwen3-32B

# Google OAuth — create credentials at https://console.cloud.google.com
# (APIs & Services -> Credentials -> OAuth client ID -> Web application).
# Add this exact redirect URI there: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Random string used to sign OAuth session cookies, e.g. `openssl rand -hex 32`
SESSION_SECRET_KEY=jdediuwniweyweuybcjsisueiak

# Daily reminder emails, sent via Gmail SMTP using an "App Password"
# (Gmail blocks regular password login for security). Setup:
#   1. Turn on 2-Step Verification on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a password for "Mail" — a 16-character code
#   4. Paste it below as GMAIL_APP_PASSWORD (with or without spaces, either works)
# Leave REMINDERS_ENABLED=false to skip this entirely — the app works fine without it.
REMINDERS_ENABLED=false
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=
REMINDER_HOUR=8
# Set this to your own timezone (list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# so "8" actually means 8 AM where you are, not 8 AM UTC. Defaulted to India time.
REMINDER_TIMEZONE=Asia/Kolkata
